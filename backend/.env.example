# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (PostgreSQL)
DB_NAME=your_database_name
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Signature Security Settings
SIGNATURE_SECRET_KEY=your-signature-secret-key
SIGNATURE_ENCRYPTION_KEY=your-base64-encryption-key
SIGNATURE_2FA_ENABLED=True
SIGNATURE_OTP_VALIDITY_MINUTES=5
SIGNATURE_MAX_OTP_ATTEMPTS=3
SIGNATURE_RATE_LIMIT_HOUR=10

# Site URL (for email links)
SITE_URL=http://localhost:8081
